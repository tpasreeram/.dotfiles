# Created by newuser for 6.9

HISTFILE=~/.zsh_history
HISTSIZE=500
SAVEHIST=500
setopt autocd
unsetopt beep
bindkey -v

zstyle :compinstall filename '/home/sreer/.zshrc'

autoload -Uz compinit
compinit

alias ls='ls --color=auto -a'

